{
code = "featureNames {\012  name \"Restore <<= >>= ||= |= as arrows\";\012};\012lookup restore_greater_greater_equal {\012  sub greater_greater_equal_start.seq equal' by equal_end.seq;\012  sub greater_greater.liga' equal by greater_greater_equal_start.seq;\012} restore_greater_greater_equal;\012\012lookup restore_less_less_equal {\012  sub less_less_equal_start.seq equal' by equal_end.seq;\012  sub less_less.liga' equal by less_less_equal_start.seq;\012} restore_less_less_equal;\012\012lookup restore_bar_bar_equal {\012  sub bar_bar_equal_start.seq equal' by equal_end.seq;\012  sub bar_bar.liga' equal by bar_bar_equal_start.seq;\012} restore_bar_bar_equal;\012\012lookup restore_bar_equal {\012  sub bar_equal_start.seq equal' by equal_end.seq;\012  sub bar' equal by bar_equal_start.seq;\012} restore_bar_equal;";
name = ss09;
},
{
code = "featureNames {\012  name \"Ligatures for Tl Fl fi fj fl ft\";\012};\012lookup T_l {\012  sub T.spacer [l l.salt_low]' by T_l.liga.ss10;\012  sub T' [l l.salt_low] by T.spacer;\012} T_l;\012\012lookup F_l {\012  sub F.spacer [l l.salt_low]' by F_l.liga.ss10;\012  sub F' [l l.salt_low] by F.spacer;\012} F_l;\012\012lookup f_i {\012  sub f.spacer [i i.salt_low]' by f_i.liga.ss10;\012  sub f' [i i.salt_low] by f.spacer;\012} f_i;\012\012lookup f_j {\012  sub f.spacer [j j.salt_low]' by f_j.liga.ss10;\012  sub f' [j j.salt_low] by f.spacer;\012} f_j;\012\012lookup f_l {\012  sub f.spacer l' by f_l.liga.ss10;\012  sub f' l by f.spacer;\012} f_l;\012\012lookup f_t {\012  sub f.spacer t' by f_t.liga.ss10;\012  sub f' t by f.spacer;\012} f_t;";
