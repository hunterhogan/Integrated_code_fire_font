{
code = "sub a by a.cv01;\012sub aacute by aacute.cv01;\012sub abreve by abreve.cv01;\012sub acircumflex by acircumflex.cv01;\012sub adieresis by adieresis.cv01;\012sub agrave by agrave.cv01;\012sub amacron by amacron.cv01;\012sub aogonek by aogonek.cv01;\012sub aring by aring.cv01;\012sub atilde by atilde.cv01;";
